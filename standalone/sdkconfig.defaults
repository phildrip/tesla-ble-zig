# ESP-IDF SDK configuration defaults for pure-Zig Tesla BLE firmware
CONFIG_IDF_TARGET="esp32c6"

# Configure Bluetooth Stack to use NimBLE (C-native stack, highly efficient)
CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=3
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=10240


# Memory and Partition sizes
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_160=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=24576
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Wi-Fi configurations
CONFIG_ESP_WIFI_ENABLED=y

# Custom Tesla BLE Configuration Defaults
CONFIG_WIFI_SSID="your_wifi_ssid"
CONFIG_WIFI_PASSWORD="your_wifi_password"
CONFIG_WIFI_HOTSPOT_PASSWORD="tesla-ble-setup"
CONFIG_MQTT_BROKER_URL="mqtt://homeassistant.local:1883"
CONFIG_MQTT_USERNAME="your_mqtt_username"
CONFIG_MQTT_PASSWORD="your_mqtt_password"
CONFIG_VEHICLE_VIN="your_vehicle_vin"
CONFIG_BLE_MAC_ADDRESS="your_ble_mac_address"
CONFIG_API_ENCRYPTION_KEY="your_api_encryption_key_base64"
CONFIG_VEHICLE_PUBLIC_KEY="your_vehicle_public_key_hex"
CONFIG_OTA_PASSWORD="your_ota_password"

