# 🔐 Tesla BLE ESPHome Secrets Template
# Rename this file to "secrets.yaml" and fill in your real details.
# DO NOT commit "secrets.yaml" to your public git repository!

wifi_ssid: "your_wifi_ssid_here"
wifi_password: "your_wifi_password_here"
wifi_hotspot_password: "tesla-ble-setup"

# The Bluetooth MAC Address of your Tesla (e.g. 74:46:B3:04:47:16)
ble_mac_address: "00:00:00:00:00:00"

# Your Tesla's 17-character VIN (Vehicle Identification Number)
tesla_vin: "17_CHAR_VIN_HERE"

# ESPHome API encryption key (32 bytes base64 encoded)
# Generate a new one using: esphome generate-key
api_encryption_key: "GENERATE_A_KEY_HERE"

# Optional OTA upload password
ota_password: "ota_password_here"
